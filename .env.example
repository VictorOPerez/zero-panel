# Base URL del backend Admin Panel API.
NEXT_PUBLIC_API_URL=https://zero-production-223c.up.railway.app

# Opcional: WebSocket endpoint (socket.io).
NEXT_PUBLIC_WS_URL=wss://zero-production-223c.up.railway.app

# Meta WhatsApp Business — Embedded Signup
# El App ID y el Embedded Signup Config ID son publicos (van al browser).
# El App Secret NUNCA va aqui — vive en el backend (META_FB_APP_SECRET).
NEXT_PUBLIC_META_FB_APP_ID=
NEXT_PUBLIC_META_FB_GRAPH_VERSION=v22.0
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=
